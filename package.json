{
  "name": "cno-reports",
  "productName": "CNO Reports",
  "version": "1.1.0",
  "description": "CNO Creative Co monthly analytics report generator — desktop app.",
  "author": "CNO Creative Co",
  "license": "UNLICENSED",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "co.cnocreative.reports",
    "productName": "CNO Reports",
    "directories": { "output": "dist-desktop", "buildResources": "build" },
    "files": [
      "electron/**/*",
      "index.html",
      "fonts.css",
      "cno-seal.png",
      "cno-logo.png",
      "apple-touch-icon.png",
      "icon-192.png",
      "icon-512.png",
      "manifest.webmanifest",
      "resources/*.woff2"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "CNO Reports"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png",
      "category": "public.app-category.business"
    },
    "dmg": { "title": "CNO Reports ${version}" }
  }
}
