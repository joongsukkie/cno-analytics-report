PORT=10000
PUBLIC_BASE_URL=http://localhost:10000
REPORT_ORIGIN=http://localhost:8777
DATABASE_URL=postgresql://user:password@localhost:5432/cno_sync

# Generate all three as long random values. TOKEN_ENCRYPTION_KEY must be 32 bytes, base64 encoded.
CNO_ADMIN_TOKEN=replace-with-a-long-random-admin-login
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key
SYNC_CRON_SECRET=replace-with-a-third-long-random-secret

# Provider apps. Values stay in the server environment and are never sent to the report.
META_CLIENT_ID=
META_CLIENT_SECRET=
META_API_VERSION=v25.0
META_SCOPES=pages_show_list,pages_read_engagement,read_insights,instagram_basic,instagram_manage_insights,ads_read

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_SCOPES=user.info.basic,user.info.stats,video.list,video.insights

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_VERSION=202601
LINKEDIN_SCOPES=r_organization_social,r_organization_admin,r_ads_reporting
